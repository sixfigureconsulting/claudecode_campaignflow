# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_YEARLY_PRICE_ID=price_...

# Encryption (32-char secret for AES-256 API key encryption)
ENCRYPTION_SECRET=your-32-character-encryption-secret

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# (Optional) Server-side AI keys for server-side fallback
# These are NOT required — users provide their own keys via the UI
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
